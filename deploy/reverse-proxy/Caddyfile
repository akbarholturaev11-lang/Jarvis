# JARVIS product backend — TLS reverse proxy (Caddy alternative).
#
# Caddy obtains and renews a real certificate automatically for the named host.
# It forwards the real scheme/client to the backend. Stock Caddy has no built-in
# request-rate limiter, so this recipe requires a provider/WAF rate limit or a
# separately reviewed Caddy module before public production use. Replace
# api.example.com and the upstream address as needed. For a native (systemd)
# deployment use 127.0.0.1:8080 as the upstream.

api.example.com {
	encode gzip

	# Strong transport security (Caddy sets sane TLS defaults automatically).
	header Strict-Transport-Security "max-age=63072000; includeSubDomains"

	# Liveness/readiness pass straight through.
	handle /healthz {
		reverse_proxy backend:8080
	}
	handle /readyz {
		reverse_proxy backend:8080
	}

	# Never expose metrics publicly; scrape internally instead.
	handle /metrics {
		respond 404
	}

	# Admin surface: optionally restrict to an operator network.
	@admin path /admin* /api/admin/*
	handle @admin {
		# @allowed remote_ip 10.0.0.0/8 203.0.113.0/24
		# handle @allowed { reverse_proxy backend:8080 }
		# respond 403
		reverse_proxy backend:8080
	}

	handle {
		reverse_proxy backend:8080 {
			header_up X-Forwarded-Proto https
			header_up X-Request-ID {http.request.uuid}
		}
	}
}
