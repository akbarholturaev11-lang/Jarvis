# JARVIS product backend — environment reference (EXAMPLE, safe to commit).
#
# Copy to a real owner-only file OUTSIDE the repository (e.g. /etc/jarvis/backend.env,
# mode 0600) and fill in real values. Generate the secret material with:
#   python -m ops.gen_secrets --out-dir /etc/jarvis/secrets \
#     --admin-subject admin:ops --allowed-hosts api.example.com
# Validate before every deploy:
#   python -m ops.validate_config --env-file /etc/jarvis/backend.env
#
# NEVER commit the real file. Secrets belong in a managed secret store and are
# materialized as owner-only files immediately before the process starts.

# --- Storage (absolute, owner-only 0700 directories) -----------------------
JARVIS_BACKEND_DATA_DIR=/var/lib/jarvis/data
JARVIS_RELEASE_ARTIFACT_ROOT=/var/lib/jarvis/artifacts

# --- Release + entitlement signing -----------------------------------------
# JSON map of trusted release public key id -> raw 32-byte Ed25519 key,
# unpadded base64url. Keep old + new ids during a rotation overlap window.
JARVIS_RELEASE_PUBLIC_KEYS_JSON={"release-key-001":"REPLACE_WITH_BASE64URL_PUBKEY"}
JARVIS_ENTITLEMENT_KEY_ID=entitlement-key-001
# Absolute, regular, owner-only 0600, raw 32-byte Ed25519 private key file.
JARVIS_ENTITLEMENT_PRIVATE_KEY_FILE=/etc/jarvis/secrets/entitlement.key
# Absolute, regular, owner-only 0600, 32-128 random bytes.
JARVIS_ACTIVATION_PEPPER_FILE=/etc/jarvis/secrets/activation.pepper
# Absolute, regular, owner-only 0600, 32-128 random bytes (MFA master key).
JARVIS_ADMIN_MFA_KEY_FILE=/etc/jarvis/secrets/admin-mfa.key

# --- Admin authentication ---------------------------------------------------
JARVIS_ADMIN_SUBJECT=admin:ops
JARVIS_ADMIN_PASSWORD_SALT_B64URL=REPLACE
JARVIS_ADMIN_PASSWORD_HASH_B64URL=REPLACE
JARVIS_ADMIN_PBKDF2_ITERATIONS=200000
JARVIS_ADMIN_SESSION_SECRET_B64URL=REPLACE
# Comma-separated exact hostnames the API answers on (no wildcard).
JARVIS_API_ALLOWED_HOSTS=api.example.com

# --- HTTPS / operational policy --------------------------------------------
# Reject non-HTTPS requests at the app (health/readiness probes stay exempt).
JARVIS_REQUIRE_HTTPS=true
# Optionally 308-redirect safe (GET/HEAD) HTTP requests to HTTPS.
JARVIS_HTTPS_REDIRECT=false
# HSTS max-age in seconds (default two years) when HTTPS is enforced.
JARVIS_HSTS_MAX_AGE=63072000
# Set a >=16 char token to enable GET /metrics (Bearer-gated). Empty = disabled.
JARVIS_METRICS_TOKEN=

# --- Network trust ----------------------------------------------------------
# CIDRs of reverse proxies whose X-Forwarded-For / X-Forwarded-Proto may be
# trusted. UNSET = forwarded headers are ignored and the socket peer wins.
JARVIS_TRUSTED_PROXIES=
# CIDRs allowed to reach the admin console (VPN/operator network). UNSET means
# the network edge is responsible for restriction.
JARVIS_ADMIN_ALLOWED_NETWORKS=

# --- Admin session windows (optional, bounded) -----------------------------
# JARVIS_ADMIN_SESSION_TTL_SECONDS=1800
# JARVIS_ADMIN_SESSION_IDLE_SECONDS=900
# JARVIS_ADMIN_REAUTH_WINDOW_SECONDS=300
# JARVIS_ADMIN_MFA_ISSUER=JARVIS Admin

# --- Manual payment instructions (optional) --------------------------------
# Absolute owner-only 0400/0600 JSON file, schema jarvis.payment-instructions.v1.
# JARVIS_PAYMENT_INSTRUCTIONS_FILE=/etc/jarvis/secrets/payment-instructions.json

# DEVELOPMENT ONLY — never set in a customer-facing deployment:
# JARVIS_ADMIN_MFA_ALLOW_PASSWORD_ONLY=true
